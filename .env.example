NODE_ENV=production
REQUIRE_OSS_STORAGE=true

# ------------------------------------------------------------
# FacetDeck runtime mode
# ------------------------------------------------------------
# oss  = open-source self-host mode (default)
# saas = full hosted mode (community + managed providers)
FACETDECK_DISTRIBUTION_MODE=oss

# Frontend build mode (must align with FACETDECK_DISTRIBUTION_MODE)
VITE_FACETDECK_MODE=oss

# ------------------------------------------------------------
# App / API server
# ------------------------------------------------------------
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
APP_NAME=FacetDeck
SQLITE_PATH=./database/auth.db
JWT_SECRET=replace-with-a-long-random-secret

# ------------------------------------------------------------
# Auth / anti-abuse
# ------------------------------------------------------------
AUTH_CODE_EXPIRES_MINUTES=10
RESET_CODE_EXPIRES_MINUTES=10
CAPTCHA_EXPIRES_MINUTES=5
CAPTCHA_LENGTH=6
CAPTCHA_NOISE=8
CAPTCHA_MAX_TRIES=3
SEND_CODE_LIMIT_PER_IP_WINDOW_MS=60000
SEND_CODE_LIMIT_PER_IP_MAX=5
SEND_CODE_LIMIT_PER_EMAIL_WINDOW_MS=60000
SEND_CODE_LIMIT_PER_EMAIL_MAX=3

# ------------------------------------------------------------
# Email (required for registration/reset email delivery)
# ------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=no-reply@example.com

# ------------------------------------------------------------
# Managed provider config (SaaS mode only)
# Keep empty in OSS mode.
# ------------------------------------------------------------
MANAGED_LLM_MODEL_ID=
MANAGED_LLM_API_KEY=
MANAGED_LLM_API_URL=
MANAGED_LLM_AUTO_CONCAT=true
MANAGED_IMG_MODEL_ID=
MANAGED_IMG_API_KEY=
MANAGED_IMG_API_URL=
MANAGED_IMG_AUTO_CONCAT=false

# ------------------------------------------------------------
# Credits / quota (mostly relevant in SaaS mode)
# ------------------------------------------------------------
INITIAL_SYSTEM_CREDITS=100000
CLOUD_DRIVE_QUOTA_BYTES=5368709120
CREDIT_COST_INPUT_PER_M_TOKENS=20000
CREDIT_COST_OUTPUT_PER_M_TOKENS=120000
CREDIT_COST_IMAGE_PER_GENERATION=2000

# ------------------------------------------------------------
# Object storage (optional; local fallback used when absent)
# ------------------------------------------------------------
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_PUBLIC_BASE_URL=
OSS_FOLDER=assets
